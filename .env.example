# ── 검색 엔진 선택 ─────────────────────────────
# meilisearch | sqlite
# 로컬에서 외부 서비스 없이 바로 테스트하려면 sqlite 권장
SEARCH_ENGINE=sqlite

# ── Meilisearch (SEARCH_ENGINE=meilisearch일 때) ──
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=masterKey
MEILISEARCH_INDEX=namuwiki

# ── SQLite (SEARCH_ENGINE=sqlite일 때) ────────────
SQLITE_DB_PATH=./data/namuwiki.db

# ── REST API 서버 ────────────────────────────────
API_PORT=3000

# ── MCP 서버 트랜스포트 ───────────────────────────
# stdio | http
MCP_TRANSPORT=stdio
MCP_HTTP_PORT=3001

# MCP 서버가 검색 요청을 보낼 REST API 주소
# (지정하지 않으면 http://localhost:{API_PORT} 사용)
API_BASE_URL=http://localhost:3000

# ── MySQL (SEARCH_ENGINE=mysql일 때) ──────────────
# MySQL 8.0+ (InnoDB FULLTEXT + ngram 파서). ngram_token_size=2면 한국어 2글자 검색 지원.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=namuwiki

# ── API 키 인증 / 부하 보호 (주로 운영=mysql용. 로컬 sqlite는 보통 불필요) ──
# 외부 요청에 API 키 강제 여부. 미설정 시 mysql 엔진이면 자동 true, 그 외 false.
# 로컬에서 키 흐름을 테스트하려면 true로 두고 ADMIN_API_TOKEN을 설정한 뒤
# POST /admin/keys 로 키를 발급해 사용한다.
REQUIRE_API_KEY=false
# 발급/폐기 엔드포인트(/admin/keys) 보호 토큰
ADMIN_API_TOKEN=
# 키 검증 캐시 TTL(ms)
API_KEY_CACHE_TTL_MS=60000

# 응답 캐시 / 동시성 / 타임아웃 (비우면 코드 기본값)
CACHE_MAX_ENTRIES=5000
CACHE_TTL_MS=300000
MAX_CONCURRENT=20
REQUEST_TIMEOUT_MS=8000
