# 서버 측 시크릿 예시.
# 두 곳에 나눠서 배치한다 (아래 주석 참고).

# ──────────────────────────────────────────────
# [1] Lightsail 서버의 ~/namuwiki-search-mcp/infra/.env 로 복사
#     docker compose -f infra/docker-compose.yml 가 읽는다.
#     (rsync 배포 시 .env는 제외되므로 서버에 수동 생성)
#
#     검색 백엔드 = AWS RDS(MySQL). api 컨테이너가 이 값으로 RDS에 연결한다.
# ──────────────────────────────────────────────

MYSQL_HOST=your-namuwiki.xxxxxxxx.ap-northeast-2.rds.amazonaws.com
MYSQL_PORT=3306
MYSQL_USER=admin
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=namuwiki

# ──────────────────────────────────────────────
# [2] 기존 tan-kim "Caddy 컨테이너" 환경에 주입
#     Caddyfile의 {$NAMU_MCP_BEARER_TOKEN} 에서 참조.
#     compose가 아니라 Caddy가 읽는 값이라는 점에 주의.
# ──────────────────────────────────────────────

# Caddy가 MCP 엔드포인트(/namuwiki) 보호에 쓰는 Bearer 토큰
NAMU_MCP_BEARER_TOKEN=change-me-to-a-strong-random-token

# Caddy가 내부 api 엔드포인트(/namuwiki-api) 보호에 쓰는 Bearer 토큰.
# Vercel REST API가 이 값을 Authorization 헤더로 보내 RDS 검색을 위임한다.
NAMU_API_TOKEN=change-me-to-another-strong-random-token
