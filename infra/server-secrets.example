# 서버 측 시크릿 예시.
# 두 곳에 나눠서 배치한다 (아래 주석 참고).

# ──────────────────────────────────────────────
# [1] Lightsail 서버의 ~/namuwiki-search-mcp/infra/.env 로 복사
#     docker compose -f infra/docker-compose.yml 가 읽는다.
#     (rsync 배포 시 .env는 제외되므로 서버에 수동 생성)
#
#     검색 백엔드 = AWS RDS(MySQL). api 컨테이너가 이 값으로 RDS에 연결한다.
#     + API 키 발급/검증(RDS api_keys 테이블)용 관리자 토큰.
# ──────────────────────────────────────────────

MYSQL_HOST=your-namuwiki.xxxxxxxx.ap-northeast-2.rds.amazonaws.com
MYSQL_PORT=3306
MYSQL_USER=admin
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=namuwiki

# 외부 요청에 API 키 강제(운영 권장).
REQUIRE_API_KEY=true
# 발급/폐기 엔드포인트(/admin/keys) 보호 토큰. 이 토큰으로 사용자 API 키를 발급·폐기한다.
ADMIN_API_TOKEN=change-me-to-a-strong-random-admin-token

# ──────────────────────────────────────────────
# [2] caddy-config 레포의 ~/caddy-config/.env 에 배치
#     caddy-config의 Caddy가 읽는다(compose가 아니라 Caddy 측 값).
#
#     Cloudflare 프록시(주황 구름) 뒤에서 TLS를 발급하려면 DNS-01 챌린지가 필요하고,
#     그때 Cloudflare API 토큰을 쓴다. (DNS Edit 권한)
#
#     ※ 과거 NAMU_MCP_BEARER_TOKEN(MCP 공유 토큰)은 폐기됐다.
#       이제 MCP는 사용자 API 키를 그대로 namu-api로 전달해 인증한다.
# ──────────────────────────────────────────────

CF_API_TOKEN=change-me-cloudflare-api-token-with-dns-edit
