# namuwiki 서버 배포용 환경변수 (AWS Lightsail).
# 서버의 ~/namuwiki-search-mcp/infra/.env 로 복사해서 사용한다.
# docker compose -f infra/docker-compose.yml 가 이 파일을 읽어 ${...}를 주입한다.
# (rsync 배포 시 .env는 제외 대상이므로 서버에 수동 생성)

# ── 검색 백엔드 = AWS RDS(MySQL). api 컨테이너(SEARCH_ENGINE=mysql)가 이 값으로 RDS에 연결 ──
MYSQL_HOST=your-namuwiki.xxxxxxxx.ap-northeast-2.rds.amazonaws.com
MYSQL_PORT=3306
MYSQL_USER=admin
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=namuwiki

# ── API 키 인증/발급 ──
# REST API(api.tan-kim.com/namuwiki)와 MCP(mcp.tan-kim.com/namuwiki)는 RDS의 api_keys로 인증한다.
# 외부 요청에 API 키 필수 여부. 운영은 true 권장(미설정 시 mysql 엔진이면 자동 true).
REQUIRE_API_KEY=true
# 발급/폐기 엔드포인트(POST/GET/DELETE /admin/keys) 보호용 관리자 토큰. 강력한 랜덤 값.
# 이 토큰으로 사용자 API 키를 발급/폐기한다. 미설정 시 발급 기능 비활성.
ADMIN_API_TOKEN=change-me-to-a-strong-random-admin-token

# ── 부하 보호 (선택 — 비우면 코드 기본값) ──
# 응답 캐시(반복 질의가 RDS를 안 치게 함)
CACHE_MAX_ENTRIES=5000
CACHE_TTL_MS=300000
# 동시 처리 요청 상한(초과 시 503) / 요청 타임아웃(ms)
MAX_CONCURRENT=20
REQUEST_TIMEOUT_MS=8000
# API 키 검증 결과 캐시 TTL(ms)
API_KEY_CACHE_TTL_MS=60000
