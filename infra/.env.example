# namuwiki 서버 배포용 환경변수 (AWS Lightsail).
# 서버의 ~/namuwiki-search-mcp/infra/.env 로 복사해서 사용한다.
# docker compose -f infra/docker-compose.yml 가 이 파일을 읽어 ${MYSQL_*}를 주입한다.
# (rsync 배포 시 .env는 제외 대상이므로 서버에 수동 생성)
#
# 검색 백엔드 = AWS RDS(MySQL). api 컨테이너(SEARCH_ENGINE=mysql 고정)가 이 값으로 RDS에 연결한다.
# MCP 보호 토큰(NAMU_MCP_BEARER_TOKEN)은 여기가 아니라 caddy-config/.env 소관이다.

MYSQL_HOST=your-namuwiki.xxxxxxxx.ap-northeast-2.rds.amazonaws.com
MYSQL_PORT=3306
MYSQL_USER=admin
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=namuwiki
